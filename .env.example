# ─────────────────────────────────────────
# HOW TO USE THIS FILE
# ─────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your own values below
# 3. Never commit your .env file to Git
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=your_postgres_username
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=readmission
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────
# MinIO (Object Storage)
# ─────────────────────────────────────────
MINIO_ROOT_USER=your_minio_username
MINIO_ROOT_PASSWORD=your_minio_password_min_8_chars
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=mlflow-artifacts

# ─────────────────────────────────────────
# MLflow
# ─────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=your_minio_username
AWS_SECRET_ACCESS_KEY=your_minio_password_min_8_chars

# ─────────────────────────────────────────
# Model
# ─────────────────────────────────────────
MODEL_NAME=readmission_predictor
MODEL_STAGE=Production